{
  "name": "Clone",
  "type": "app",
  "version": "2.0.0",
  "categories": [
    "system",
    "data operations",
    "project management",
    "images",
    "videos",
    "pointclouds",
    "dicom",
    "meshes"
  ],
  "description": "Clone project or dataset to selected workspace or project, works with all project types: images, videos, 3d, dicom, meshes",
  "docker_image": "supervisely/sys-clone-project:0.0.3-test-hardened",
  "instance_version": "6.16.19",
  "main_script": "src/main.py",
  "modal_template": "src/modal.html",
  "modal_template_state": {
    "projectName": "",
    "datasetName": ""
  },
  "task_location": "workspace_tasks",
  "isolate": true,
  "headless": true,
  "icon": "https://github.com/supervisely-ecosystem/sys-clone-project/releases/download/v1.1.6/sys-clone-project-icon.jpg",
  "icon_background": "#FFFFFF",
  "context_menu": {
    "target": [
      "images_project",
      "videos_project",
      "point_cloud_project",
      "volumes_project",
      "point_cloud_episodes_project",
      "meshes_project",
      "images_dataset",
      "videos_dataset",
      "point_cloud_dataset",
      "volumes_dataset",
      "point_cloud_episodes_dataset",
      "meshes_dataset"
    ]
  },
  "poster": "https://github.com/supervisely-ecosystem/sys-clone-project/releases/download/v1.1.6/sys-clone-project-poster.jpg"
}
